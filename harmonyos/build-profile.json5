{
    "apiType": "stageMode",
    "buildOption": {
        "externalNativeOptions": {
            "path": "src/main/cpp/CMakeLists.txt",
            "arguments": "",
            "cppFlags": "",
            "abiFilters": [
                "armeabi-v7a",
                "arm64-v8a"
            ]
        }
    },
    "buildOptionSet": [
        {
            "name": "release",
            "arkOptions": {
                "obfuscation": {
                    "ruleOptions": {
                        "enable": true,
                        "files": [
                            "./build-profile.json5"
                        ]
                    }
                }
            }
        }
    ],
    "products": [
        {
            "name": "default",
            "signingConfig": "default",
            "compatibleSdkVersion": "5.0.0(12)",
            "runtimeOS": "HarmonyOS"
        }
    ]
}
